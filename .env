PORT=8443
ENV=dev

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=auth_user
DB_PASSWORD=auth_pass
DB_NAME=authdb
DB_SSLMODE=disable


# JWT (RS256)
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ISSUER=authsvc
JWT_AUDIENCE=goAuth
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h # 30 days

# HTTPS TLS certs (for dev; in prod use a load balancer / ingress)
TLS_CERT_PATH=web/certs/dev.crt
TLS_KEY_PATH=web/certs/dev.key